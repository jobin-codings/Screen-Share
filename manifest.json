{
    "manifest_version": 3,
    "name": "Pro Screen Share",
    "version": "1.0",
    "description": "Professional WebRTC Screen Sharing Extension",
    "permissions": [
        "tabCapture",
        "desktopCapture",
        "activeTab",
        "storage"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_title": "Open Pro Screen Share",
        "default_icon": "icons/icon_new.svg"
    },
    "icons": {
        "16": "icons/icon_new.svg",
        "48": "icons/icon_new.svg",
        "128": "icons/icon_new.svg"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "icons/*"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}